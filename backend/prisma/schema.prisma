generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Complaint {
  id          String   @id
  category    String
  description String
  status      String   @default("filed") // filed, review, action, resolved
  evidenceUrl String?
  createdAt   DateTime @default(now())
}

model Alert {
  id          Int      @id @default(autoincrement())
  type        String
  title       String
  description String
  severity    String
  createdAt   DateTime @default(now())
}
